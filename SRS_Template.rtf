\par \pard\plain \s0\rtlch\af5\afs20\alang1025 \ltrch\lang1033\langfe2052\hich\af0\loch\ql\widctlpar\hyphpar0\sb0\sa0\ltrpar\cf0\f0\fs20\lang1033\kerning0\dbch\af5\langfe2052\fi0\li1440\lin1440{\loch\cf17\loch
